# CourseForge — .gitignore

# ------------------------------------------------------------------ #
# Python                                                              #
# ------------------------------------------------------------------ #
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ------------------------------------------------------------------ #
# Ambientes virtuais                                                  #
# ------------------------------------------------------------------ #
.venv/
venv/
env/
.env/
ENV/

# ------------------------------------------------------------------ #
# Conteúdo gerado pela plataforma (não versionar)                    #
# Os cursos gerados são arquivos de trabalho do USUÁRIO.             #
# Para versionar cursos específicos, use repositórios separados.     #
# ------------------------------------------------------------------ #
convertidos/
prompts_gerados/

# ------------------------------------------------------------------ #
# Logs                                                                #
# ------------------------------------------------------------------ #
courseforge.log
*.log

# ------------------------------------------------------------------ #
# IDEs e editores                                                     #
# ------------------------------------------------------------------ #
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.vs/

# ------------------------------------------------------------------ #
# Sistema operacional                                                 #
# ------------------------------------------------------------------ #
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------------ #
# Pytest                                                              #
# ------------------------------------------------------------------ #
.pytest_cache/
.coverage
htmlcov/
